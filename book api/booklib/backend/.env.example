# Copy this file to `.env` and fill in your own values.

# Used to sign JWT access tokens and the session cookie. Any long random string.
SECRET_KEY=change-this-to-a-long-random-string

# Where the frontend is served from (used to redirect back after OAuth login).
FRONTEND_URL=http://localhost:8000

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- GitHub OAuth ---
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: http://localhost:8000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
